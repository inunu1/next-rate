// ============================================================================
// 【Prisma Schema - 2ロール最小構成（リレーションなし・enum使用）】
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// 【Enum】システムロール（SaaSオーナー / 団体オーナー）
// ============================================================================
enum SystemRole {
  owner   // SaaSオーナー
  user    // 団体オーナー
}

// ============================================================================
// 【User】ログインユーザー
// - SaaSオーナー or 団体オーナー
// ============================================================================
model User {
  id             String     @id @default(uuid())
  email          String     @unique
  name           String?
  hashedPassword String

  systemRole     SystemRole @default(user)

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// ============================================================================
// 【Organization】団体
// - ownerId で User と紐づく（論理的参照）
// ============================================================================
model Organization {
  id        String   @id @default(uuid())
  name      String
  ownerId   String   // User.id（論理的参照）
  createdAt DateTime @default(now())
}

// ============================================================================
// 【Player】団体に属する棋士
// ============================================================================
model Player {
  id             String   @id @default(uuid())
  organizationId String   // Organization.id（論理的参照）

  name           String
  initialRate    Int
  currentRate    Int

  createdAt      DateTime @default(now())
  deletedAt      DateTime?
}

// ============================================================================
// 【Result】対局結果
// ============================================================================
model Result {
  id             String   @id @default(uuid())
  organizationId String   // Organization.id（論理的参照）

  winnerId       String   // Player.id
  winnerName     String
  winnerRate     Int

  loserId        String   // Player.id
  loserName      String
  loserRate      Int

  matchDate      Int      // YYYYMMDD
  roundIndex     Int

  updatedAt      DateTime @updatedAt

  @@unique([organizationId, matchDate, roundIndex, winnerId])
  @@unique([organizationId, matchDate, roundIndex, loserId])
}
