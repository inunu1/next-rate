generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  name            String?
  hashedPassword  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Player {
  id              String    @id @default(uuid())
  name            String    @unique   // ★ ユニーク制約を追加
  initialRate     Int
  currentRate     Int
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?
}

model Result {
  id              String    @id @default(uuid())
  winnerId        String
  winnerName      String
  winnerRate      Int
  loserId         String
  loserName       String
  loserRate       Int
  matchDate       Int
  roundIndex      Int
  updatedAt       DateTime  @updatedAt

  @@unique([winnerId, loserId, matchDate, roundIndex])
  @@unique([matchDate, roundIndex, winnerId])
  @@unique([matchDate, roundIndex, loserId])
}